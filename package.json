{
  "name": "quay-so-hop-tri",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n fe,be -c blue,green \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "dev:fe": "npm run dev -w frontend",
    "dev:be": "npm run dev -w backend",
    "build": "npm run build -w frontend",
    "typecheck": "npm run typecheck -w frontend",
    "export-data": "npm run export-data -w frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
